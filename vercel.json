{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/auto-mt.html", "destination": "/auto-mt.html" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
